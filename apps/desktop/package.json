{
  "name": "@ftc-sim/desktop",
  "version": "1.2.2",
  "private": true,
  "description": "FTC Sim desktop launcher — serve UI, spawn match server, open browser",
  "main": "dist/main.js",
  "author": "VibeCodedFTCSIM",
  "scripts": {
    "build": "tsc",
    "start": "electron .",
    "dev": "tsc && electron .",
    "prepare:resources": "node scripts/prepare-resources.mjs",
    "pack:dir": "pnpm prepare:resources && pnpm build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir --config.directories.output=release/electron",
    "dist": "pnpm run pack:dir && node scripts/make-release-zip.mjs",
    "release": "node scripts/release.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/nat-upnp": "^1.1.5",
    "@types/node": "^22.10.7",
    "cross-env": "^10.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "com.vibecodedftcsim.app",
    "productName": "FTC Sim",
    "publish": {
      "provider": "github",
      "owner": "Pleasantnoob",
      "repo": "VibeCodedFTCSIM"
    },
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "launcher.html"
    ],
    "extraResources": [
      {
        "from": "resources/web",
        "to": "web",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/match-server",
        "to": "match-server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "README.txt",
        "to": "README.txt"
      }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "asar": true
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "nat-upnp": "^1.1.1"
  }
}
